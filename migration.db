-- 1. ซ่อนเนื้อหาประเภท สัตว์ (type_id=2), พืช (type_id=1), จุลินทรีย์ (type_id=3)
--    ที่มี created_at น้อยกว่าวันที่ปัจจุบัน

UPDATE content SET is_hidden = 1 WHERE type_id IN (1, 2, 3) AND created_at < NOW();
